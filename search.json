---
layout: null
---
[
  {% assign items = site.posts | concat: site.pages %}
  {% for item in items %}
  {
    "title": "{{ item.title | escape }}",
    "url": "{{ item.url }}",
    "content": "{{ item.content | strip_html | normalize_whitespace | escape }}"
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
